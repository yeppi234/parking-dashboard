{
  "name": "parking-dashboard",
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/proxy.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/proxy/(.*)",
      "dest": "/api/proxy"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/proxy"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
